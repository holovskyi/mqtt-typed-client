# Rust build artifacts
**/target/
**/*.rs.bk
Cargo.lock

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
.env.*.local

# Exception: example configs are safe to commit (NO SECRETS!)
!examples/.env         # ⚠️ ONLY safe defaults - no passwords/keys!
!examples/.env.example

# Documentation build
doc/

# Auto-generated documentation files
docs/generated/

# Coverage reports
*.profraw
tarpaulin-report.html
lcov.info

# Backup files
*.bak
*.orig

# Local dev TLS certs — throwaway self-signed material for the localhost broker.
# Generate with dev/certs/generate-certs.sh; NEVER commit (a private key leaked
# into the published 0.1.0 crate this way — do not repeat it).
dev/certs/*.pem
dev/certs/*.srl
dev/certs/*.csr
